{
  "name": "@superdoc-examples/ai-footnote-tool-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter superdoc build",
    "dev": "concurrently -k -n API,WEB -c blue,green \"node server.mjs\" \"vite --host 127.0.0.1 --port 5181 --strictPort\"",
    "dev:server": "node server.mjs",
    "dev:web": "vite",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.33.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "superdoc": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
