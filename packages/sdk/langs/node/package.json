{
  "name": "@superdoc-dev/sdk",
  "version": "1.20.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "skills",
    "tools"
  ],
  "scripts": {
    "build": "node scripts/embed-prompts.mjs && tsc && rollup -c rollup.cjs.config.mjs && rm -rf dist/prompts && mkdir -p dist/prompts && cp src/prompts/*.md dist/prompts/",
    "typecheck": "tsc --noEmit",
    "smoke:product-action": "node scripts/product-action-smoke.mjs",
    "prepack": "rm -rf tools && cp -r ../../tools ./tools && rm -f ./tools/__init__.py",
    "postpack": "rm -rf tools && ln -s ../../tools tools"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "rollup": "catalog:",
    "typescript": "catalog:"
  },
  "optionalDependencies": {
    "@superdoc-dev/sdk-darwin-arm64": "workspace:*",
    "@superdoc-dev/sdk-darwin-x64": "workspace:*",
    "@superdoc-dev/sdk-linux-x64": "workspace:*",
    "@superdoc-dev/sdk-linux-arm64": "workspace:*",
    "@superdoc-dev/sdk-windows-x64": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
